{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/generate-audio/route.ts": { "maxDuration": 120 },
    "app/api/generate-video/route.ts": { "maxDuration": 300 },
    "app/api/master-pipeline/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/master-pipeline", "schedule": "0 6 * * *" },
    { "path": "/api/cron/publish-youtube",   "schedule": "0 14 * * *" },
    { "path": "/api/cron/publish-tiktok",    "schedule": "0 12 * * *" },
    { "path": "/api/cron/publish-instagram", "schedule": "0 15 * * *" },
    { "path": "/api/cron/publish-discord",   "schedule": "0 9 * * *" }
  ]
}
